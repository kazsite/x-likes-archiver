# ==========================================
# 1. バージョン管理・Git関連
# ==========================================
.git
.gitignore
.gitattributes

# ==========================================
# 2. 環境変数・秘密情報（イメージに絶対含めない）
# ==========================================
.env
.env.*
!.env.example
*.pem
*.key
*.secret

# ==========================================
# 3. 開発ツール・エディタ設定
# ==========================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db

# ==========================================
# 4. パッケージマネージャー・依存関係
# ==========================================
# Node.js (Next.js等のダッシュボード用)
node_modules/
.npm/
pnpm-lock.yaml
yarn-error.log

# Python (スクリプト・収集ロジック用)
.venv/
venv/
ENV/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.poetry/
poetry.lock

# ==========================================
# 5. ビルド成果物・キャッシュ・ログ
# ==========================================
# Node.js / Next.js
.next/
out/
build/
dist/
.next_cache/

# ログファイル
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ==========================================
# 6. ローカルのデータ・アーカイブ（重要）
# ==========================================
# ローカルでテストダウンロードした画像やSQLite等のDB
*.mp4
*.jpg
*.jpeg
*.png
*.gif
*.db
*.sqlite3
# mitmproxy等のログやモックデータ
dumpfile
